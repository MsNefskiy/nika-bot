generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id               String   @id @default(uuid())
  discordId       String   @unique
  username        String
  stars           Int      @default(0)         // Звезды
  joinedAt        DateTime @default(now())      // Дата первого входа
  
  // Задания
  lastTaskDate     DateTime?
  currentTaskIndex Int?
  isTaskDone       Boolean   @default(false)
  isTaskPending    Boolean   @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Связи
  tribunesCreated  Tribune[]        @relation("TribuneCreator")
  tribuneHistory   TribuneHistory[] @relation("HostHistory")
  reprimands       Reprimand[]      @relation("UserReprimands")
}

model Reprimand {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("UserReprimands", fields: [userId], references: [discordId])
  reason    String
  authorId  String
  createdAt DateTime @default(now())
}

model Tribune {
  id          String   @id @default(uuid())
  type        String   // Синяя кнопка, Быстрые свидания и т.д.
  dateTime    String   // Запланированное время строкой
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED
  creatorId   String
  creator     User     @relation("TribuneCreator", fields: [creatorId], references: [discordId])
  
  // Привязка к сообщению для живых обновлений
  messageId   String?
  channelId   String?

  // Участники на местах
  slot1_1     String?
  slot1_2     String?
  slot2_1     String?
  slot2_2     String?

  createdAt   DateTime @default(now())
}

model TribuneHistory {
  id          String   @id @default(uuid())
  type        String
  startTime   String
  closedAt    DateTime @default(now())
  hostId      String   // ID ведущего (того, кто завершил)
  host        User     @relation("HostHistory", fields: [hostId], references: [discordId])
  
  // Кто был на трибуне
  participants String? 
}
