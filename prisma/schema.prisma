generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String   @id @default(uuid())
  discordId     String   @unique
  username      String
  points        Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Связи с трибунами
  tribunesCreated  Tribune[]        @relation("TribuneCreator")
  tribuneHistory   TribuneHistory[] @relation("HostHistory")
}

model Tribune {
  id          String   @id @default(uuid())
  type        String   // Синяя кнопка, Быстрые свидания и т.д.
  dateTime    String   // Запланированное время строкой
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED
  creatorId   String
  creator     User     @relation("TribuneCreator", fields: [creatorId], references: [discordId])
  
  // Привязка к сообщению для живых обновлений
  messageId   String?
  channelId   String?

  // Участники на местах
  slot1_1     String?
  slot1_2     String?
  slot2_1     String?
  slot2_2     String?

  createdAt   DateTime @default(now())
}

model TribuneHistory {
  id          String   @id @default(uuid())
  type        String
  startTime   String
  closedAt    DateTime @default(now())
  hostId      String   // ID ведущего (того, кто завершил)
  host        User     @relation("HostHistory", fields: [hostId], references: [discordId])
  
  // Кто был на трибуне
  participants String? 
}
